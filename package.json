{
  "name": "obsidian-notespark",
  "version": "0.1.0",
  "description": "AI-powered quotes, reflections, and prompts for Obsidian notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "mistral",
    "quotes",
    "journaling"
  ],
  "author": "Arta",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.1",
    "obsidian": "^1.9.14",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
